{
    "name": "lattice/notifications",
    "description": "Notification system with multi-channel support for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "notifications",
        "channels",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/notifications"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "lattice/mail": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Notifications\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Notifications\\Tests\\": "tests/"
        }
    }
}
