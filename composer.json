{
    "name": "lattice/notifications",
    "description": "Notification system with multi-channel support for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../contracts"
        },
        {
            "type": "path",
            "url": "../mail"
        }
    ],
    "require": {
        "php": "^8.4",
        "lattice/contracts": "*",
        "lattice/mail": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Notifications\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Notifications\\Tests\\": "tests/"
        }
    }
}
